{
	"name": "assignment-app",
	"private": true,
	"version": "0.0.1",
	"description": "A public marketing surface and an authenticated dashboard built with SvelteKit, Tailwind CSS",
	"type": "module",
	"author": {
		"name": "Denis Donici",
		"email": "skryonline@gmail.com"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/gevera/assignment-app.git"
	},
	"homepage": "https://github.com/gevera/assignment-app",
	"packageManager": "pnpm@11.12.0",
	"engines": {
		"node": "^24.6.0",
		"pnpm": "^11.10.0"
	},
	"lint-staged": {
		"*.{js,ts,svelte}": [
			"prettier --write",
			"eslint --fix --no-warn-ignored"
		],
		"*.{json,md,css,html,yml,yaml,mjs,cjs}": "prettier --write --ignore-unknown"
	},
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync && husky || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"typecheck": "svelte-kit sync && tsc --noEmit",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"budget": "node scripts/check-bundle-budget.mjs",
		"lhci": "node scripts/run-lhci.mjs",
		"ci": "pnpm lint && pnpm typecheck && pnpm check && pnpm test:unit -- --run && pnpm build && pnpm budget"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.12.1",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@lhci/cli": "^0.15.1",
		"@playwright/test": "^1.61.1",
		"@resvg/resvg-js": "^2.6.2",
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/kit": "^2.69.2",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26",
		"@vitest/browser-playwright": "^4.1.10",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"playwright": "^1.61.1",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"satori": "^0.26.0",
		"satori-html": "^0.3.2",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.2",
		"tailwindcss": "^4.3.2",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.63.0",
		"vite": "^8.1.4",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.10",
		"vitest-browser-svelte": "^3.0.0"
	},
	"dependencies": {
		"@fontsource/ibm-plex-sans": "^5.2.8",
		"@fontsource/source-serif-4": "^5.2.9",
		"fuse.js": "^7.4.2",
		"jose": "^6.2.3",
		"sveltekit-i18n": "^2.4.2",
		"ts-pattern": "^5.9.0",
		"web-vitals": "^5.3.0",
		"zod": "^4.4.3"
	}
}
