# Signing key for session JWTs (min 32 characters). Copy to `.env` for local dev.
AUTH_SECRET=dev-only-change-me-to-a-long-random-string

# Public site origin used for canonical URLs, hreflang alternates and JSON-LD.
PUBLIC_SITE_URL=http://localhost:5173

# Fraction of sessions [0..1] that ship web-vitals RUM to /api/beacon.
# Errors always ship regardless. Defaults: 1 in dev, 0.1 in production.
PUBLIC_RUM_SAMPLE_RATE=1
